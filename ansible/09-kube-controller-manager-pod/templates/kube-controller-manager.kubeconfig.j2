apiVersion: v1
kind: Config

clusters:
- cluster:
    certificate-authority: /etc/controller-manager/pki/ca/{{ pki_cas.kubernetes.path_cert | basename }}
    server: https://{{ vip_api_fqdn }}:{{ porta_kube_apiserver }}
  name: kubernetes

users:
- name: system:kube-controller-manager
  user:
    client-certificate: /etc/controller-manager/pki/kubeconfig/{{ pki_certs.kube_controller_manager.path_cert | format(inventory_hostname) | basename }}
    client-key: /etc/controller-manager/pki/kubeconfig/{{ pki_certs.kube_controller_manager.path_chave | format(inventory_hostname) | basename }}

contexts:
- context:
    cluster: kubernetes
    user: system:kube-controller-manager
  name: system:kube-controller-manager@kubernetes
current-context: system:kube-controller-manager@kubernetes
